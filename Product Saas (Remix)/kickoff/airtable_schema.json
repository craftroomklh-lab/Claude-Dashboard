{
  "schema_version": "1.3.0",
  "base_name": "DPF_Core",
  "tables": [
    {
      "name": "SystemConfig",
      "description": "Singleton row. Go-live gates and global toggles. Read by every scenario's pre-flight module.",
      "fields": [
        { "name": "ConfigID", "type": "autoNumber", "primary": true },
        { "name": "MasterEnabled", "type": "checkbox", "default": false },
        { "name": "DryRun", "type": "checkbox", "default": true },
        { "name": "LegalEntityConfirmed", "type": "checkbox", "default": false, "notes": "LLC formed, EIN issued, business bank account active" },
        { "name": "InsuranceBoundUntil", "type": "date", "notes": "E&O + Cyber + GL bound through this date" },
        { "name": "EtsyShopOwnerType", "type": "singleSelect", "options": ["individual", "business"], "default": "individual" },
        { "name": "DisclosureApprovedAt", "type": "dateTime" },
        { "name": "DisclosureText", "type": "longText", "default": "Designed using AI-assisted tooling; quality-reviewed by hand before listing." },
        { "name": "DailyDiscoveryCap", "type": "number", "default": 3, "notes": "Days 1-30: 3, days 31-90: 8, days 91+: 15" },
        { "name": "DailyApprovalsCap", "type": "number", "default": 3 },
        { "name": "ε_ExplorationRate", "type": "number", "default": 0.20 },
        { "name": "QAPassThreshold", "type": "number", "default": 0.80 },
        { "name": "PriceDiscountMin", "type": "number", "default": 0.10 },
        { "name": "PriceDiscountMax", "type": "number", "default": 0.15 },
        { "name": "WebhookSharedSecret", "type": "singleLineText", "permissions": "admin-only" },
        { "name": "MakeWebhookURL_Distribution", "type": "url" },
        { "name": "WebhookSuccessURL", "type": "url" },
        { "name": "WebhookFailureURL", "type": "url" },
        { "name": "LastConfigReviewAt", "type": "dateTime" }
      ]
    },
    {
      "name": "Niches",
      "fields": [
        { "name": "NicheID", "type": "autoNumber", "primary": true },
        { "name": "NicheName", "type": "singleLineText" },
        { "name": "NicheSlug", "type": "singleLineText" },
        { "name": "Status", "type": "singleSelect", "options": ["Active", "Paused", "Deprecated"], "default": "Active" },
        { "name": "PriorityScore", "type": "number", "default": 0.50 },
        { "name": "PinPriority", "type": "checkbox" },
        { "name": "PinnedScore", "type": "number" },
        { "name": "TopKeywords", "type": "multipleSelects" },
        { "name": "AvgMarketPrice", "type": "currency" },
        { "name": "FirstLiveAt", "type": "dateTime" },
        { "name": "LastDiscoveryAt", "type": "dateTime" },
        { "name": "DaysAtLowPriority", "type": "number" },
        { "name": "DaysPaused", "type": "number" },
        { "name": "CreatedAt", "type": "createdTime" }
      ]
    },
    {
      "name": "MasterLibrary",
      "fields": [
        { "name": "TemplateID", "type": "autoNumber", "primary": true },
        { "name": "TemplateName", "type": "singleLineText" },
        { "name": "Format", "type": "singleSelect", "options": ["Canva", "Adobe", "Notion", "Sheets", "PDF"] },
        { "name": "Active", "type": "checkbox", "default": true },
        { "name": "CompatibleProductTypes", "type": "multipleSelects", "options": ["Printable", "DigitalPlanner", "Template", "ClipArt", "Worksheet", "Other"] },
        { "name": "CompatibleNiches", "type": "linkToAnotherRecord", "linkedTable": "Niches" },
        { "name": "SchemaJSON", "type": "longText" },
        { "name": "DesignConstraints", "type": "longText", "notes": "JSON: layout, typography, content_structure, tone, anti_patterns, format_specific" },
        { "name": "EtsyTaxonomyID", "type": "number" },
        { "name": "SupportsInteractive", "type": "checkbox" },
        { "name": "InteractiveCapabilities", "type": "multipleSelects", "options": ["Fillable", "Hyperlinked", "Formula", "Conditional", "Database", "Automated", "Calculated"] },
        { "name": "AdobeFormFields", "type": "longText" },
        { "name": "SheetsFormulaMap", "type": "longText" },
        { "name": "NotionInteractiveFeatures", "type": "longText" },
        { "name": "TemplateAsset", "type": "multipleAttachments" },
        { "name": "CanvaTemplateID", "type": "singleLineText" },
        { "name": "NotionDuplicateURL", "type": "url" },
        { "name": "UsageCount", "type": "number", "default": 0 },
        { "name": "CreatedBy", "type": "collaborator" },
        { "name": "CreatedAt", "type": "createdTime" }
      ]
    },
    {
      "name": "TrendSignals",
      "fields": [
        { "name": "SignalID", "type": "autoNumber", "primary": true },
        { "name": "Source", "type": "singleSelect", "options": ["Etsy", "CreativeMarket"] },
        { "name": "ScrapeRunID", "type": "singleLineText" },
        { "name": "Niche", "type": "linkToAnotherRecord", "linkedTable": "Niches" },
        { "name": "RawTitle", "type": "singleLineText" },
        { "name": "RawURL", "type": "url" },
        { "name": "RawHeroImageURL", "type": "url" },
        { "name": "ObservedPrice", "type": "currency" },
        { "name": "ReviewCount", "type": "number" },
        { "name": "AvgRating", "type": "number" },
        { "name": "TopComplaints", "type": "longText", "notes": "PII-sanitized" },
        { "name": "KeywordsExtracted", "type": "multipleSelects" },
        { "name": "InteractiveKeywordsFound", "type": "multipleSelects", "options": ["Fillable", "Hyperlinked", "Formula", "Conditional", "Database", "Automated", "Calculated", "Interactive"] },
        { "name": "InteractivityHints", "type": "longText" },
        { "name": "DemandScore", "type": "number" },
        { "name": "ComplexityScore", "type": "number" },
        { "name": "IPRiskScore", "type": "number" },
        { "name": "SelectedByFilter", "type": "checkbox" },
        { "name": "CapturedAt", "type": "dateTime" }
      ]
    },
    {
      "name": "Products",
      "fields": [
        { "name": "ProductID", "type": "autoNumber", "primary": true },
        { "name": "Status", "type": "singleSelect", "options": ["Draft","Generating","QA_Pending","Ready_For_Review","Approved","Publishing","Live","QA_Failed","Copy_Failed","Rejected","Archived"], "default": "Draft" },
        { "name": "Niche", "type": "linkToAnotherRecord", "linkedTable": "Niches" },
        { "name": "SourceSignal", "type": "linkToAnotherRecord", "linkedTable": "TrendSignals" },
        { "name": "MasterTemplateUsed", "type": "linkToAnotherRecord", "linkedTable": "MasterLibrary" },
        { "name": "ProductType", "type": "singleSelect", "options": ["Printable","DigitalPlanner","Template","ClipArt","Worksheet","Other"] },
        { "name": "TargetFormat", "type": "singleSelect", "options": ["Canva", "Adobe", "Notion", "Sheets", "PDF"] },
        { "name": "IsInteractive", "type": "checkbox" },
        { "name": "InteractiveMethod", "type": "singleSelect", "options": ["Adobe_FillablePDF","Sheets_Formulas","Notion_Database","Canva_None","Static","FALLBACK_STATIC"] },
        { "name": "InteractiveFeatures", "type": "multipleSelects", "options": ["Fillable","Hyperlinked","Formula","Conditional","Database","Automated","Calculated"] },
        { "name": "InternalName", "type": "singleLineText" },
        { "name": "ValueProp", "type": "longText" },
        { "name": "GeneratedAssets", "type": "multipleAttachments" },
        { "name": "DeliveryArtifacts", "type": "longText", "notes": "JSON of buyer-facing files" },
        { "name": "Mockups", "type": "linkToAnotherRecord", "linkedTable": "Mockups" },
        { "name": "SEOTitle", "type": "singleLineText" },
        { "name": "SEODescription", "type": "longText" },
        { "name": "SEOTags", "type": "longText", "notes": "Comma-separated; exactly 13" },
        { "name": "MarketAvgPrice", "type": "currency" },
        { "name": "LaunchPrice", "type": "currency" },
        { "name": "PriceSchedule", "type": "longText", "notes": "JSON: launch_price, standard_price, effective_at" },
        { "name": "QAVerdict", "type": "singleSelect", "options": ["Pass", "Fail", "Pending"] },
        { "name": "QAScore", "type": "number" },
        { "name": "DesignQualityScore", "type": "number" },
        { "name": "AssetGenerationLog", "type": "longText" },
        { "name": "RejectionReason", "type": "longText" },
        { "name": "Approve", "type": "checkbox", "notes": "TRIGGER for Airtable Automation → Make.com publish webhook" },
        { "name": "ApprovedAt", "type": "dateTime" },
        { "name": "EtsyListingID", "type": "singleLineText" },
        { "name": "EtsyListingURL", "type": "url" },
        { "name": "PublishedAt", "type": "dateTime" },
        { "name": "CreatedAt", "type": "createdTime" },
        { "name": "LastModified", "type": "lastModifiedTime" }
      ]
    },
    {
      "name": "Mockups",
      "fields": [
        { "name": "MockupID", "type": "autoNumber", "primary": true },
        { "name": "Product", "type": "linkToAnotherRecord", "linkedTable": "Products" },
        { "name": "Variant", "type": "singleSelect", "options": ["Hero", "LifestyleA", "LifestyleB"] },
        { "name": "IsHero", "type": "checkbox" },
        { "name": "Generator", "type": "singleSelect", "options": ["DALL-E_3", "Midjourney", "SDXL"] },
        { "name": "PromptUsed", "type": "longText" },
        { "name": "Image", "type": "multipleAttachments" },
        { "name": "ImageURL", "type": "url" },
        { "name": "Width", "type": "number" },
        { "name": "Height", "type": "number" },
        { "name": "PerceptualHash", "type": "singleLineText" },
        { "name": "AltText", "type": "longText" },
        { "name": "Approved", "type": "checkbox", "default": true },
        { "name": "GeneratedAt", "type": "createdTime" }
      ]
    },
    {
      "name": "SalesPerformance",
      "fields": [
        { "name": "PerfID", "type": "autoNumber", "primary": true },
        { "name": "Product", "type": "linkToAnotherRecord", "linkedTable": "Products" },
        { "name": "WindowStart", "type": "date" },
        { "name": "WindowEnd", "type": "date" },
        { "name": "Views", "type": "number" },
        { "name": "Favorites", "type": "number" },
        { "name": "UnitsSold", "type": "number" },
        { "name": "Revenue", "type": "currency" },
        { "name": "ConversionRate", "type": "formula", "formula": "IF({Views}>0, {UnitsSold}/{Views}, 0)" },
        { "name": "Locked", "type": "checkbox" },
        { "name": "PulledAt", "type": "dateTime" }
      ]
    },
    {
      "name": "NichePerformance",
      "fields": [
        { "name": "NPerfID", "type": "autoNumber", "primary": true },
        { "name": "Niche", "type": "linkToAnotherRecord", "linkedTable": "Niches" },
        { "name": "WindowEnd", "type": "date" },
        { "name": "LiveProductCount", "type": "number" },
        { "name": "TotalViews", "type": "number" },
        { "name": "TotalFavorites", "type": "number" },
        { "name": "TotalUnitsSold", "type": "number" },
        { "name": "TotalRevenue", "type": "currency" },
        { "name": "RevenuePerProduct", "type": "currency" },
        { "name": "AvgConversionRate", "type": "number" },
        { "name": "ComputedAt", "type": "createdTime" }
      ]
    },
    {
      "name": "PriorityHistory",
      "fields": [
        { "name": "HistID", "type": "autoNumber", "primary": true },
        { "name": "Niche", "type": "linkToAnotherRecord", "linkedTable": "Niches" },
        { "name": "FromScore", "type": "number" },
        { "name": "ToScore", "type": "number" },
        { "name": "Reason", "type": "longText" },
        { "name": "StatusChange", "type": "singleLineText" },
        { "name": "PerformanceComponents", "type": "longText" },
        { "name": "ChangedAt", "type": "createdTime" }
      ]
    },
    {
      "name": "RunLog",
      "fields": [
        { "name": "LogID", "type": "autoNumber", "primary": true },
        { "name": "Scenario", "type": "singleSelect", "options": ["Discovery","Production","Webhook","SalesPull","WindowClose","PriorityRecompute","SaleEvent"] },
        { "name": "RunID", "type": "singleLineText" },
        { "name": "Severity", "type": "singleSelect", "options": ["info","warning","error","critical"] },
        { "name": "Stage", "type": "singleLineText" },
        { "name": "Product", "type": "linkToAnotherRecord", "linkedTable": "Products" },
        { "name": "Niche", "type": "linkToAnotherRecord", "linkedTable": "Niches" },
        { "name": "Message", "type": "longText" },
        { "name": "Payload", "type": "longText" },
        { "name": "OccurredAt", "type": "createdTime" }
      ]
    },
    {
      "name": "BlockedKeywords",
      "fields": [
        { "name": "Term", "type": "singleLineText", "primary": true },
        { "name": "Category", "type": "singleSelect", "options": ["Brand","Trademark","Adult","Other"] },
        { "name": "AddedBy", "type": "collaborator" },
        { "name": "AddedAt", "type": "createdTime" }
      ]
    },
    {
      "name": "Costs",
      "fields": [
        { "name": "CostID", "type": "autoNumber", "primary": true },
        { "name": "Date", "type": "date" },
        { "name": "Vendor", "type": "singleSelect", "options": ["openai","anthropic","apify","browseai","piapi","canva","adobe","make","etsy"] },
        { "name": "Ops", "type": "number" },
        { "name": "SpendUSD", "type": "currency" }
      ]
    }
  ],
  "automations": [
    {
      "name": "Approve → Publish to Etsy",
      "trigger": "When record matches conditions",
      "table": "Products",
      "conditions": [
        "Approve is checked",
        "Status = Ready_For_Review",
        "QAVerdict = Pass",
        "EtsyListingID is empty",
        "SEOTitle is not empty",
        "SEODescription is not empty",
        "SEOTags is not empty",
        "LaunchPrice > 0",
        "GeneratedAssets is not empty",
        "DeliveryArtifacts is not empty"
      ],
      "actions": [
        "Find SystemConfig singleton",
        "Find Mockups linked to Product",
        "Run Script (assemble + HMAC sign + POST to Make.com webhook) — see kickoff/airtable_automation_script.js",
        "Conditional Slack notify on halted_at_gate / halted_at_cap / webhook_failed"
      ]
    },
    {
      "name": "Webhook → Mark Live (success callback)",
      "trigger": "Custom webhook — WebhookSuccessURL",
      "actions": ["Update Products: Status=Live, EtsyListingID, EtsyListingURL, PublishedAt"]
    },
    {
      "name": "Webhook → Mark Rejected (failure callback)",
      "trigger": "Custom webhook — WebhookFailureURL",
      "actions": ["Update Products: Status=Rejected, RejectionReason; Slack alert"]
    }
  ]
}
